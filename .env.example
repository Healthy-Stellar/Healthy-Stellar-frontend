# =============================================================================
# Healthy-Stellar Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local or any file containing real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------

# Base URL for the Healthy-Stellar REST API.
# Required. Provided by the backend team.
# Example (local dev): http://localhost:3000/api/v1
# Example (staging):   https://api-staging.healthy-stellar.io/v1
# Example (prod):      https://api.healthy-stellar.io/v1
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# -----------------------------------------------------------------------------
# Stellar Network
# -----------------------------------------------------------------------------

# Stellar network to connect to.
# Optional. Defaults to "testnet" if not set.
# Accepted values: "testnet" | "mainnet"
# WARNING: Setting this to "mainnet" means transactions use real XLM.
#          Ensure all other Stellar variables are also updated for mainnet.
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Horizon API endpoint used to submit transactions and query the ledger.
# Optional. Defaults to the Stellar Foundation testnet URL if not set.
# Testnet:  https://horizon-testnet.stellar.org  (provided by Stellar Foundation)
# Mainnet:  https://horizon.stellar.org           (provided by Stellar Foundation)
# Self-hosted: https://horizon.your-domain.com
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
